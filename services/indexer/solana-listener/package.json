{
  "name": "solana-listener",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/solana-listener.js",
    "dev:listener": "ts-node src/solana-listener.ts",
    "dev:indexer": "ts-node src/index.ts",
    "dev": "concurrently -c \"cyan,magenta\" -n \"SOLANA,INDEXER\" \"npm run dev:listener\" \"npm run dev:indexer\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@project-serum/anchor": "^0.25.0",
    "@solana/web3.js": "^1.69.0",
    "dotenv": "^16.1.4",
    "express": "^5.2.1",
    "kafkajs": "^2.2.4",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
